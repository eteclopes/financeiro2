// ============================================================
// SISTEMA DE GESTAO FINANCEIRA PESSOAL INTELIGENTE
// schema.prisma — Etapa 4
// Mapeado 1:1 para database.sql (mesmos nomes de tabela/coluna via @@map/@map)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------- ENUMS ----------------

enum PaymentMethod {
  cash
  pix
  debit
  credit
  transfer
}


enum IncomeOrigin {
  digital
  physical
}

enum CategoryType {
  income
  expense
}

enum MonthStatus {
  open
  closed
}

enum DebtStatus {
  active
  settled
}

enum ExpenseType {
  priority
  fixed
  variable
  card
}

enum ExpenseStatus {
  pending
  partial
  paid
  late
  settled
}

enum CardInvoiceStatus {
  open
  closed
  paid
}

enum SavingsType {
  deposit
  withdraw
}

enum SavingsOrigin {
  balance
  external
}

enum GoalStatus {
  active
  completed
  cancelled
}

enum GoalContributionType {
  contribution
  refund
}

enum AlertSeverity {
  info
  warning
  critical
}

enum SimulationType {
  pay_debt
  anticipate_installments
  save_monthly
  reduce_category
  increase_income
}

// ---------------- MODELS ----------------

model User {
  id           BigInt   @id @default(autoincrement())
  name         String   @db.VarChar(120)
  email        String   @unique @db.VarChar(190)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  categories         Category[]
  refreshTokens      RefreshToken[]
  passwordResets     PasswordReset[]
  months             Month[]
  incomeTemplates    IncomeTemplate[]
  incomes            Income[]
  fixedExpenseTemplates FixedExpenseTemplate[]
  debts              Debt[]
  cards              Card[]
  cardPurchases      CardPurchase[]
  expenses           Expense[]
  savingsTransactions SavingsTransaction[]
  goals              Goal[]
  alerts             Alert[]
  financialHealthScores FinancialHealthScore[]
  auditLogs          AuditLog[]
  simulations        Simulation[]

  @@map("users")
}

model RefreshToken {
  id         BigInt    @id @default(autoincrement())
  userId     BigInt    @map("user_id")
  tokenHash  String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordReset {
  id         BigInt    @id @default(autoincrement())
  userId     BigInt    @map("user_id")
  tokenHash  String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt  DateTime  @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

model Category {
  id        BigInt       @id @default(autoincrement())
  userId    BigInt?      @map("user_id")
  name      String       @db.VarChar(80)
  type      CategoryType
  isDefault Boolean      @default(false) @map("is_default")
  // Orçamento mensal opcional (só faz sentido para categorias de despesa).
  // Null = sem limite definido, comportamento atual preservado.
  monthlyLimit Decimal?  @map("monthly_limit") @db.Decimal(12, 2)
  createdAt DateTime     @default(now()) @map("created_at")

  user                User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomeTemplates     IncomeTemplate[]
  incomes             Income[]
  fixedExpenseTemplates FixedExpenseTemplate[]
  debts               Debt[]
  cardPurchases       CardPurchase[]
  expenses            Expense[]

  @@unique([userId, name, type])
  @@index([type])
  @@map("categories")
}

model Month {
  id        BigInt      @id @default(autoincrement())
  userId    BigInt      @map("user_id")
  month     Int         @db.SmallInt
  year      Int         @db.SmallInt
  status    MonthStatus @default(open)
  closedAt  DateTime?   @map("closed_at")
  createdAt DateTime    @default(now()) @map("created_at")

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes           Income[]
  expenses          Expense[]
  cardInvoices      CardInvoice[]
  goalContributions GoalContribution[]
  alerts            Alert[]
  financialHealthScore FinancialHealthScore?

  @@unique([userId, month, year])
  @@map("months")
}

model IncomeTemplate {
  id            BigInt        @id @default(autoincrement())
  userId        BigInt        @map("user_id")
  description   String        @db.VarChar(160)
  value         Decimal       @db.Decimal(12, 2)
  categoryId    BigInt        @map("category_id")
  paymentMethod PaymentMethod @map("payment_method")
  incomeDay     Int           @default(1) @map("income_day") @db.SmallInt
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])
  incomes  Income[]

  @@map("income_templates")
}

model Income {
  id            BigInt        @id @default(autoincrement())
  userId        BigInt        @map("user_id")
  monthId       BigInt        @map("month_id")
  templateId    BigInt?       @map("template_id")
  description   String        @db.VarChar(160)
  value         Decimal       @db.Decimal(12, 2)
  categoryId    BigInt        @map("category_id")
  paymentMethod PaymentMethod @map("payment_method")
  origin        IncomeOrigin  @default(digital)
  incomeDate    DateTime      @map("income_date") @db.Date
  observation   String?       @db.VarChar(255)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  month    Month           @relation(fields: [monthId], references: [id])
  template IncomeTemplate? @relation(fields: [templateId], references: [id])
  category Category        @relation(fields: [categoryId], references: [id])

  @@index([userId, monthId])
  @@map("incomes")
}

model FixedExpenseTemplate {
  id            BigInt        @id @default(autoincrement())
  userId        BigInt        @map("user_id")
  description   String        @db.VarChar(160)
  categoryId    BigInt        @map("category_id")
  value         Decimal       @db.Decimal(12, 2)
  dueDay        Int           @map("due_day") @db.SmallInt
  paymentMethod PaymentMethod @default(transfer) @map("payment_method")
  cardId        BigInt?       @map("card_id")
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category  @relation(fields: [categoryId], references: [id])
  card     Card?     @relation(fields: [cardId], references: [id])
  expenses Expense[]

  @@map("fixed_expense_templates")
}

model Debt {
  id                 BigInt     @id @default(autoincrement())
  userId             BigInt     @map("user_id")
  description        String     @db.VarChar(160)
  categoryId         BigInt     @map("category_id")
  totalValue         Decimal    @map("total_value") @db.Decimal(12, 2)
  installmentsCount  Int        @map("installments_count") @db.SmallInt
  installmentValue   Decimal    @map("installment_value") @db.Decimal(12, 2)
  flexiblePayment    Boolean    @default(false) @map("flexible_payment")
  dueDay             Int        @map("due_day") @db.SmallInt
  status             DebtStatus @default(active)
  remainingBalance   Decimal    @map("remaining_balance") @db.Decimal(12, 2)
  pendingCarryOver   Decimal    @default(0) @map("pending_carry_over") @db.Decimal(12, 2)
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category  @relation(fields: [categoryId], references: [id])
  expenses Expense[]

  @@index([userId, status])
  @@map("debts")
}

model Card {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt   @map("user_id")
  name        String   @db.VarChar(80)
  color       String   @default("#6366F1") @db.VarChar(20)
  limitValue  Decimal  @map("limit_value") @db.Decimal(12, 2)
  closingDay  Int      @map("closing_day") @db.SmallInt
  dueDay      Int      @map("due_day") @db.SmallInt
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardPurchases CardPurchase[]
  cardInvoices  CardInvoice[]
  fixedExpenseTemplates FixedExpenseTemplate[]

  @@index([userId])
  @@map("cards")
}

model CardPurchase {
  id                BigInt   @id @default(autoincrement())
  userId            BigInt   @map("user_id")
  cardId            BigInt   @map("card_id")
  description       String   @db.VarChar(160)
  categoryId        BigInt   @map("category_id")
  totalValue        Decimal  @map("total_value") @db.Decimal(12, 2)
  installmentsCount Int      @default(1) @map("installments_count") @db.SmallInt
  installmentValue  Decimal  @map("installment_value") @db.Decimal(12, 2)
  purchaseDate      DateTime @map("purchase_date") @db.Date
  createdAt         DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  card     Card      @relation(fields: [cardId], references: [id])
  category Category  @relation(fields: [categoryId], references: [id])
  expenses Expense[]

  @@index([cardId])
  @@map("card_purchases")
}

model CardInvoice {
  id              BigInt            @id @default(autoincrement())
  cardId          BigInt            @map("card_id")
  monthId         BigInt            @map("month_id")
  referenceMonth  Int               @map("reference_month") @db.SmallInt
  referenceYear   Int               @map("reference_year") @db.SmallInt
  closingDate     DateTime          @map("closing_date") @db.Date
  dueDate         DateTime          @map("due_date") @db.Date
  totalValue      Decimal           @default(0) @map("total_value") @db.Decimal(12, 2)
  status          CardInvoiceStatus @default(open)
  paidAt          DateTime?         @map("paid_at")
  createdAt       DateTime          @default(now()) @map("created_at")

  card     Card      @relation(fields: [cardId], references: [id])
  month    Month     @relation(fields: [monthId], references: [id])
  expenses Expense[]

  @@unique([cardId, referenceMonth, referenceYear])
  @@map("card_invoices")
}

model Expense {
  id              BigInt        @id @default(autoincrement())
  userId          BigInt        @map("user_id")
  monthId         BigInt        @map("month_id")
  type            ExpenseType
  description     String        @db.VarChar(160)
  categoryId      BigInt        @map("category_id")
  dueDate         DateTime      @map("due_date") @db.Date
  competenceMonth Int?          @map("competence_month") @db.SmallInt
  competenceYear  Int?          @map("competence_year") @db.SmallInt
  value           Decimal       @db.Decimal(12, 2)
  paidAmount      Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  paidAt          DateTime?     @map("paid_at") @db.Date
  status          ExpenseStatus @default(pending)
  paymentMethod   PaymentMethod? @map("payment_method")
  fixedTemplateId BigInt?       @map("fixed_template_id")
  debtId          BigInt?       @map("debt_id")
  cardInvoiceId   BigInt?       @map("card_invoice_id")
  cardPurchaseId  BigInt?       @map("card_purchase_id")
  observation     String?       @db.VarChar(255)
  deletedAt       DateTime?     @map("deleted_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  month         Month                 @relation(fields: [monthId], references: [id])
  category      Category              @relation(fields: [categoryId], references: [id])
  fixedTemplate FixedExpenseTemplate? @relation(fields: [fixedTemplateId], references: [id])
  debt          Debt?                 @relation(fields: [debtId], references: [id])
  cardInvoice   CardInvoice?          @relation(fields: [cardInvoiceId], references: [id])
  cardPurchase  CardPurchase?         @relation(fields: [cardPurchaseId], references: [id])

  @@index([userId, monthId, type])
  @@index([userId, status])
  @@index([cardInvoiceId])
  @@unique([fixedTemplateId, competenceMonth, competenceYear])
  @@map("expenses")
}

model SavingsTransaction {
  id              BigInt        @id @default(autoincrement())
  userId          BigInt        @map("user_id")
  type            SavingsType
  value           Decimal       @db.Decimal(12, 2)
  // Só relevante para type=deposit: de onde veio o dinheiro. 'balance' (o
  // padrão, preserva o comportamento de sempre) sai do saldo disponível
  // agora; 'external' é dinheiro que já estava guardado fora do app —
  // só passa a ser rastreado aqui, sem sair de lugar nenhum.
  origin          SavingsOrigin @default(balance)
  transactionDate DateTime      @map("transaction_date") @db.Date
  observation     String?       @db.VarChar(255)
  balanceAfter    Decimal       @map("balance_after") @db.Decimal(12, 2)
  createdAt       DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("savings_transactions")
}

model Goal {
  id          BigInt     @id @default(autoincrement())
  userId      BigInt     @map("user_id")
  name        String     @db.VarChar(120)
  description String?    @db.VarChar(255)
  targetValue Decimal    @map("target_value") @db.Decimal(12, 2)
  targetDate  DateTime?  @map("target_date") @db.Date
  status      GoalStatus @default(active)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions GoalContribution[]

  @@index([userId])
  @@map("goals")
}

model GoalContribution {
  id               BigInt               @id @default(autoincrement())
  goalId           BigInt               @map("goal_id")
  monthId          BigInt               @map("month_id")
  value            Decimal              @db.Decimal(12, 2)
  type             GoalContributionType @default(contribution)
  contributionDate DateTime             @map("contribution_date") @db.Date
  createdAt        DateTime             @default(now()) @map("created_at")

  goal  Goal  @relation(fields: [goalId], references: [id], onDelete: Cascade)
  month Month @relation(fields: [monthId], references: [id])

  @@index([goalId])
  @@map("goal_contributions")
}

model Alert {
  id         BigInt        @id @default(autoincrement())
  userId     BigInt        @map("user_id")
  monthId    BigInt        @map("month_id")
  type       String        @db.VarChar(60)
  severity   AlertSeverity @default(info)
  message    String        @db.VarChar(255)
  createdAt  DateTime      @default(now()) @map("created_at")
  readAt     DateTime?     @map("read_at")
  resolvedAt DateTime?     @map("resolved_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  month Month @relation(fields: [monthId], references: [id], onDelete: Cascade)

  @@unique([userId, monthId, type])
  @@index([userId, monthId])
  @@map("alerts")
}

model FinancialHealthScore {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt   @map("user_id")
  monthId       BigInt   @unique @map("month_id")
  score         Int      @db.SmallInt
  breakdownJson Json     @map("breakdown_json")
  createdAt     DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  month Month @relation(fields: [monthId], references: [id], onDelete: Cascade)

  @@map("financial_health_scores")
}

model AuditLog {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt   @map("user_id")
  entity       String   @db.VarChar(60)
  entityId     BigInt   @map("entity_id")
  action       String   @db.VarChar(40)
  oldValueJson Json?    @map("old_value_json")
  newValueJson Json?    @map("new_value_json")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entity, entityId])
  @@map("audit_log")
}

model Simulation {
  id          BigInt         @id @default(autoincrement())
  userId      BigInt         @map("user_id")
  type        SimulationType
  name        String         @db.VarChar(160)
  inputJson   Json           @map("input_json")
  monthsAhead Int            @default(12) @map("months_ahead") @db.SmallInt
  createdAt   DateTime       @default(now()) @map("created_at")

  user    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  results SimulationResult[]

  @@index([userId])
  @@map("simulations")
}

model SimulationResult {
  id           BigInt   @id @default(autoincrement())
  simulationId BigInt   @map("simulation_id")
  monthIndex   Int      @map("month_index") @db.SmallInt
  month        Int      @db.SmallInt
  year         Int      @db.SmallInt
  baselineNet  Decimal  @map("baseline_net") @db.Decimal(12, 2)
  scenarioNet  Decimal  @map("scenario_net") @db.Decimal(12, 2)
  difference   Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")

  simulation Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  @@unique([simulationId, monthIndex])
  @@map("simulation_results")
}
