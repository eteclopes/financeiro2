# Copie este arquivo para .env e preencha com seus valores reais.
# Nunca commitar o .env real no repositorio.

# Runtime da aplicação: use o Transaction Pooler do Supabase (porta 6543).
# `pgbouncer=true` desativa prepared statements incompatíveis com o pooler.
# Copie a URL em Supabase > Connect > Transaction pooler.
DATABASE_URL="postgresql://postgres.PROJECT_REF:SUA_SENHA@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma CLI/Migrate: use a conexão direta ou o Session Pooler (porta 5432).
# Nunca use a porta 6543 para `DIRECT_URL`.
DIRECT_URL="postgresql://postgres.PROJECT_REF:SUA_SENHA@aws-0-REGION.pooler.supabase.com:5432/postgres"

PORT=3333
NODE_ENV=development

# Origens permitidas para CORS. Pode informar mais de uma, separadas por vírgula.
# Em produção sempre use a URL completa com https://. O código também corrige
# automaticamente valores sem protocolo, mas é melhor configurar corretamente.
CORS_ORIGIN="http://localhost:5173,https://financeiro2-six.vercel.app"

# Opcionais: autorizam somente os previews automáticos deste projeto/equipe Vercel.
# Ex.: financeiro2-git-master-eteclopes-projects.vercel.app
CORS_VERCEL_PROJECT="financeiro2"
CORS_VERCEL_TEAM="eteclopes-projects"

# Segredos JWT — gere valores aleatorios fortes (ex: openssl rand -hex 64)
JWT_ACCESS_SECRET="troque-este-valor-por-um-segredo-forte-de-access-token"
JWT_ACCESS_EXPIRES_IN="15m"

JWT_REFRESH_EXPIRES_IN_DAYS=30

# Reset de senha
PASSWORD_RESET_EXPIRES_IN_HOURS=1

# URL do frontend, usada para montar o link de redefinição de senha enviado por e-mail
FRONTEND_URL="http://localhost:5173"

# E-mail transacional (recuperacao de senha) — opcional em dev.
# Sem SMTP_HOST configurado, o e-mail so e logado no console, nao enviado de verdade.
# Exemplos de provedor: Resend, SendGrid, Amazon SES, ou qualquer SMTP (ex: Gmail com senha de app).
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="FinançasPro <no-reply@financaspro.app>"

# Plano Pro vitalício via Stripe Checkout (pagamento único)
# Crie um produto/preço de pagamento único no Stripe e copie o Price ID (price_...).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_LIFETIME_PRICE_ID=""
STRIPE_API_BASE="https://api.stripe.com"
STRIPE_API_VERSION="2026-06-24.dahlia"
PRO_LIFETIME_PRICE_LABEL="Oferta vitalícia"

# Conta Pro de teste local/staging: npm run seed:pro-test
PRO_TEST_NAME="Conta Pro Teste"
PRO_TEST_EMAIL="teste.pro@financehub.local"
PRO_TEST_PASSWORD="FinanceHubPro@2026"
# Em produção/staging público, o script recusa por padrão. Ao liberar, troque obrigatoriamente a senha padrão.
ALLOW_PRO_TEST_ACCOUNT=false
