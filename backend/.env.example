# Copie este arquivo para .env e preencha com seus valores reais.
# Nunca commitar o .env real no repositorio.

# String de conexao do PostgreSQL (Supabase). Pegue em: Project Settings > Database > Connection string (URI)
# Use a "Connection pooling" (porta 6543) em producao no Render.
DATABASE_URL="postgresql://postgres:SUASENHA@db.xxxxxxxxxxxx.supabase.co:5432/postgres"

# OBRIGATORIA — schema.prisma usa "directUrl" para o Prisma Migrate (o pooler
# do Supabase nao suporta as operacoes que migrate precisa fazer). Pegue em:
# Project Settings > Database > Connection string > aba "Direct connection"
# (porta 5432, host db.xxxxxxxxxxxx.supabase.co, SEM ser o dominio do pooler).
# Sem esta variavel, "prisma generate" e "prisma migrate deploy" falham —
# inclusive no build de producao.
DIRECT_URL="postgresql://postgres:SUASENHA@db.xxxxxxxxxxxx.supabase.co:5432/postgres"

PORT=3333
NODE_ENV=development

# Origem permitida para CORS (URL do frontend React)
CORS_ORIGIN="http://localhost:5173"

# Segredos JWT — gere valores aleatorios fortes (ex: openssl rand -hex 64)
JWT_ACCESS_SECRET="troque-este-valor-por-um-segredo-forte-de-access-token"
JWT_ACCESS_EXPIRES_IN="15m"

JWT_REFRESH_EXPIRES_IN_DAYS=30

# Reset de senha
PASSWORD_RESET_EXPIRES_IN_HOURS=1

# URL do frontend, usada para montar o link de redefinição de senha enviado por e-mail
FRONTEND_URL="http://localhost:5173"

# E-mail transacional (recuperacao de senha) — opcional em dev.
# Sem SMTP_HOST configurado, o e-mail so e logado no console, nao enviado de verdade.
# Exemplos de provedor: Resend, SendGrid, Amazon SES, ou qualquer SMTP (ex: Gmail com senha de app).
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="FinançasPro <no-reply@financaspro.app>"
